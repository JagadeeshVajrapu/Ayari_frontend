{
  "name": "ayari-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/prepare-dev.mjs",
    "dev": "next dev --turbopack -p 3001",
    "dev:clean": "node scripts/prepare-dev.mjs --clean && next dev --turbopack -p 3001",
    "build": "next build && node scripts/verify-build.mjs",
    "build:only": "next build",
    "verify:build": "node scripts/verify-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.2.3",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.544.0",
    "next": "^15.5.3",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.80.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2"
  }
}
