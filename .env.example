# Production example:
# NEXT_PUBLIC_API_URL=https://your-api.hostingersite.com/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://your-api.hostingersite.com
# NEXT_PUBLIC_SITE_URL=https://ayaricreations.com
#
# Hostinger deploy checklist (avoids ChunkLoadError / MIME text/plain):
# 1. Pull latest master
# 2. rm -rf .next && npm ci && npm run build
# 3. Redeploy the FULL app including the entire .next folder
# 4. Purge Hostinger CDN / clear cache
# 5. Hard-refresh the browser (Ctrl+Shift+R)

NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Razorpay — must match RAZORPAY_KEY_ID in backend/.env (public key only)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
